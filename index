<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// Données PDF en base64
const PDF_B64 = {
  'foncier': '',
  'engie':   ''
};

// État de chaque PDF
const pdfState = {
  'foncier': { doc: null, page: 1, loading: false },
  'engie':   { doc: null, page: 1, loading: false }
};

// Convertit base64 en Uint8Array
function b64toUint8(b64) {
  const bin = atob(b64);
  const arr = new Uint8Array(bin.length);
  for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
  return arr;
}

// Rend une page sur le canvas
async function renderPage(id, pageNum) {
  const state = pdfState[id];
  if (!state.doc) return;
  const page = await state.doc.getPage(pageNum);
  const canvas = document.getElementById('canvas-' + id);
  const container = canvas.parentElement;
  const scale = container.clientWidth / page.getViewport({ scale: 1 }).width;
  const viewport = page.getViewport({ scale: scale * window.devicePixelRatio || scale });
  canvas.width  = viewport.width;
  canvas.height = viewport.height;
  canvas.style.width  = container.clientWidth + 'px';
  canvas.style.height = (viewport.height / (window.devicePixelRatio || 1)) + 'px';
  await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
  document.getElementById('pageinfo-' + id).textContent =
    'page ' + pageNum + ' / ' + state.doc.numPages;
  state.page = pageNum;
}

// Charge et affiche le PDF
async function loadPDF(id) {
  const state = pdfState[id];
  if (state.doc || state.loading) { renderPage(id, state.page); return; }
  state.loading = true;
  const canvas = document.getElementById('canvas-' + id);
  canvas.style.height = '200px';
  const ctx = canvas.getContext('2d');
  canvas.width = 800; canvas.height = 200;
  ctx.fillStyle = '#EEF2F5';
  ctx.fillRect(0, 0, 800, 200);
  ctx.fillStyle = '#0D7A72';
  ctx.font = '14px JetBrains Mono, monospace';
  ctx.textAlign = 'center';
  ctx.fillText('Chargement du PDF...', 400, 100);
  try {
    const data = b64toUint8(PDF_B64[id]);
    state.doc = await pdfjsLib.getDocument({ data }).promise;
    renderPage(id, 1);
  } catch(e) {
    ctx.fillStyle = '#C94F3A';
    ctx.fillText('Erreur de chargement : ' + e.message, 400, 100);
  }
  state.loading = false;
}

// Navigation pages
function changePage(id, delta) {
  const state = pdfState[id];
  if (!state.doc) return;
  const next = state.page + delta;
  if (next >= 1 && next <= state.doc.numPages) renderPage(id, next);
}

// Patch toggleViewer pour charger le PDF à la première ouverture
document.addEventListener('DOMContentLoaded', function() {
  const _orig = window.toggleViewer;
  window.toggleViewer = function(id) {
    _orig(id);
    const wrap = document.getElementById('viewer-' + id);
    if (wrap && wrap.classList.contains('open') && (id === 'foncier' || id === 'engie')) {
      loadPDF(id);
    }
  };
});
</script>
